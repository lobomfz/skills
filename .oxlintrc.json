{
  "rules": {
    "lobomfz/no-nullish-type-laundering": "error",
    "lobomfz/no-awaited-return-chain": "error",
    "lobomfz/prefer-inverted-early-return": "error",
    "lobomfz/no-await-in-if-test": "error",
    "lobomfz/no-trivial-alias": "error",
    "lobomfz/no-compound-boolean-return": "error",
    "lobomfz/no-empty-object-default": "error",
    "lobomfz/prefer-interface-extends": "error",
    "lobomfz/no-error-instance-narrowing": "error",
    "lobomfz/no-export-function": "off",
    "lobomfz/no-nullish-coalescing": "off",
    "lobomfz/no-query-options-query-key": "error",
    "lobomfz/no-ternary-as-optional-chain": "error",
    "lobomfz/no-ternary-in-jsx": "error",
    "lobomfz/no-typographic-unicode": "error",

    "no-unused-vars": "warn",
    "no-await-in-loop": "off",
    "explicit-length-check": "off",
    "no-array-callback-reference": "off",
    "max-lines": ["off", { "max": 500 }],
    "max-lines-per-function": ["off", { "max": 150 }],
    "unicorn/consistent-function-scoping": "off",
    "no-warning-comments": "off",
    "no-array-sort": "off",
    "strict-boolean-expressions": "off",
    "no-confusing-void-expression": "off",
    "no-misused-promises": "off",
    "no-floating-promises": "off",
    "require-array-sort-compare": "off",
    "no-unsafe-return": "off",
    "no-loop-func": "off",
    "eslint/eqeqeq": "off",
    "complexity": ["warn", { "max": 40 }],
    "max-depth": ["warn", { "max": 4 }],
    "max-nested-callbacks": ["warn", { "max": 4 }],
    "no-map-spread": "off",
    "no-shadow": "off",
    "consistent-type-imports": "error",
    "prefer-nullish-coalescing": "off",
    "no-new": "off",
    "prefer-readonly-parameter-types": "off",
    "strict-void-return": "off",
    "no-unsafe-member-access": "off",
    "no-unsafe-assignment": "off",
    "unbound-method": "off",
    "consistent-return": "off",
    "no-unnecessary-condition": "error",
    "no-unsafe-type-assertion": "off",
    "no-unsafe-argument": "off",
    "no-unsafe-call": "off",
    "return-await": "off"
  },
  "jsPlugins": ["./dist/plugin.js"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error",
    "pedantic": "error"
  },
  "ignorePatterns": ["dist", "node_modules", "*.config.*", "*.gen.ts", "*.js"]
}
